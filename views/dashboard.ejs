<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Особистий кабінет</title>
    <link rel="stylesheet" href="/css/main.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Poppins:wght@500;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="container">
    <!-- Улучшенное приветствие -->
    <div class="welcome-card">
        <div class="welcome-avatar">
            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 12C14.21 12 16 10.21 16 8C16 5.79 14.21 4 12 4C9.79 4 8 5.79 8 8C8 10.21 9.79 12 12 12ZM12 14C9.33 14 4 15.34 4 18V20H20V18C20 15.34 14.67 14 12 14Z" fill="#f4c2c2"/>
            </svg>
        </div>
        <div class="welcome-info">
            <h1 id="welcomeTitle">Ласкаво просимо!</h1>
            <p id="welcome" class="welcome-name"></p>
            <div class="role-badge" id="roleBadge">
                <span id="role"></span>
            </div>
        </div>
    </div>
</div>

<%- include ("blocks/area") -%>
<script src="/js/dashboard.js"></script>
<script src="/js/readArea.js"></script>
</body>
</html>