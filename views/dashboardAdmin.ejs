<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Особистий кабінет — Адмін</title>
    <link rel="stylesheet" href="/css/main.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Poppins:wght@500;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="container">
    <!-- Покращене привітання -->
    <div class="welcome-card">
        <div class="welcome-avatar">
            <svg width="60" height="60" viewBox="0 0 24 24" fill="none">
                <path d="M12 12C14.21 12 16 10.21 16 8C16 5.79 14.21 4 12 4C9.79 4 8 5.79 8 8C8 10.21 9.79 12 12 12ZM12 14C9.33 14 4 15.34 4 18V20H20V18C20 15.34 14.67 14 12 14Z" fill="#f4c2c2"/>
            </svg>
            <div class="admin-crown">👑</div>
        </div>
        <div class="welcome-info">
            <h1 id="welcomeTitle">Ласкаво просимо!</h1>
            <h1 id="welcome" class="welcome-name"></h1>
            <div class="role-badge" id="roleBadge">
                <span id="role"></span>
                <span id="welcome"></span>
            </div>                      
        </div>
    </div>

    <!-- ===== GRID ДЛЯ ВСЬОГО ІНТЕРФЕЙСУ ===== -->
    <div class="admin-layout">

        <!-- ===== РЕЄСТРАЦІЯ ===== -->
        <div class="card registration-card">
            <h2>
                <span class="card-icon">➕</span>
                Реєстрація користувача
            </h2>

            <div class="input-group">
                <label>Логін</label>
                <input type="text" id="newLogin" placeholder="Введіть логін">
            </div>
            
            <div class="input-group">
                <label>Пароль</label>
                <input type="password" id="newPassword" placeholder="Введіть пароль">
            </div>

            <div class="input-group">
                <label>Роль користувача</label>
                <select id="newRole">
                    <option value="SECURITY">👤 SECURITY</option>
                    <option value="ADMIN">👑 ADMIN</option>
                    <option value="PERSONNEL">👤 PERSONNEL</option>
                    <option value="SECRETARY">👤 SECRETARY</option>
                    <option value="MARKETING">👤 MARKETING</option>
                    <option value="ACCOUNTING">👤 ACCOUNTING</option>
                    <option value="ACCOUNTING_V2">👤 ACCOUNTING_V2</option>
                    <option value="ARCHIVE">👤 ARCHIVE</option>
                    <option value="EQUIPMENT">👤 EQUIPMENT</option>
                    <option value="COMM_ENGINEERS">👤 COMM_ENGINEERS</option>
                    <option value="ROCKET_ENGINEERS">👤 ROCKET_ENGINEERS</option>
                    <option value="HIGH_ENGINEERS">👤 HIGH_ENGINEERS</option>
                </select>
            </div>

            <button onclick="registerUser()" class="register-btn">
                <span>Зареєструвати</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                    <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2"/>
                </svg>
            </button>

            <p id="registerMsg" class="form-message"></p>
        </div>

        <!-- ===== СПИСОК КОРИСТУВАЧІВ ===== -->
        <div class="card users-card">
            <h2>
                <span class="card-icon">👥</span>
                Список користувачів
            </h2>

            <div class="table-controls">
                <button onclick="loadUsers()" class="refresh-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <path d="M23 4V10H17M1 20V14H7..." stroke="currentColor" stroke-width="2"/>
                    </svg>
                    Оновити список
                </button>
                <div class="user-stats">
                    <span id="userCount">0</span> користувачів
                </div>
            </div>

            <div class="table-wrapper">
                <table id="usersTable">
                    <thead>
                        <tr>
                            <th>№</th>
                            <th>ID</th>
                            <th>Пароль</th>
                            <th>Логін</th>
                            <th>Роль</th>
                        </tr>
                    </thead>
                    <tbody id="usersTableBody"></tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<!-- ===== FILE MANAGER (AREA) ===== -->
<%- include ("blocks/area") -%>

<!-- ===== JS ===== -->
<script src="/js/dashboard.js"></script>
<script src="/js/funcAdmin.js"></script>
<script src="/js/readArea.js"></script>

</body>
</html>