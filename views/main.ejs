<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Авторизація</title>
    <link rel="stylesheet" href="/css/main.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Poppins:wght@500;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="container center">
    <!-- Додаємо красиву картку з рамкою -->
    <div class="login-card">
        <div class="login-card-inner">
            <div class="login-header">
                <div class="login-icon">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
                        <path d="M12 12C14.21 12 16 10.21 16 8C16 5.79 14.21 4 12 4C9.79 4 8 5.79 8 8C8 10.21 9.79 12 12 12ZM12 14C9.33 14 4 15.34 4 18V20H20V18C20 15.34 14.67 14 12 14Z" fill="#f4c2c2"/>
                    </svg>
                </div>
                <h1>Вхід у систему</h1>
                <p class="login-subtitle">Ласкаво просимо! Будь ласка, увійдіть</p>
            </div>

            <form id="loginForm">
                <div class="input-group">
                    <label for="username">Логін</label>
                    <input type="text" id="username" placeholder="Введіть ваш логін" required>
                    <div class="input-focus-effect"></div>
                </div>

                <div class="input-group">
                    <label for="password">Пароль</label>
                    <input type="password" id="password" placeholder="Введіть пароль" required>
                    <div class="input-focus-effect"></div>
                </div>

                <div class="login-options">
                    <label class="checkbox-label">
                        <input type="checkbox" id="remember">
                        <span>Запам’ятати мене</span>
                    </label>
                    <a href="#" class="forgot-link">Забули пароль?</a>
                </div>

                <button type="submit" class="login-btn">
                    <span>Увійти</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                        <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2"/>
                    </svg>
                </button>
            </form>

            <div class="login-footer">
                <p>Немає акаунта? <a href="#">Зверніться до адміністратора</a></p>
            </div>

            <p id="error" class="error"></p>
        </div>
    </div>
</div>

<script src="/js/login.js"></script>
</body>
</html>